# MySQL / MariaDB connection
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DB=cdengineering

# Or set one full URL instead of the parts above:
# DATABASE_URL=mysql+pymysql://user:pass@host:3306/cdengineering?charset=utf8mb4

# Company letterhead defaults shown on proposal letters
